# Dependencies
node_modules/

# Wrangler local state (includes local D1 SQLite files)
.wrangler/
.dev.vars

# Environment secrets — never commit
.env
.env.*
!.env.example
!**/.env.example

# Home GPS Bridge runtime
tools/home-gps-bridge/runtime/*.pid
tools/home-gps-bridge/logs/*
!tools/home-gps-bridge/logs/.gitkeep
!tools/home-gps-bridge/runtime/.gitkeep

# WeatherFront OBS Controller (runtime stays in LOCALAPPDATA; ignore local accidents)
tools/weatherfront-obs-controller/.env
tools/weatherfront-obs-controller/node_modules/
tools/weatherfront-obs-controller/playwright-report/
tools/weatherfront-obs-controller/test-results/

# OS / editor
.DS_Store
Thumbs.db
*.log

# TypeScript build output (we use wrangler, not tsc emit)
dist/

# Android build output
android-gps/app/build/
android-gps/.gradle/

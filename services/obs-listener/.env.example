# Local OBS listener (copy to .env — never commit secrets)

# HTTP API the Cloudflare Worker (or LAN clients) call
LISTENER_HOST=127.0.0.1
LISTENER_PORT=8791
LISTENER_AUTH_TOKEN=change-me-to-a-long-random-token

# Optional: pull OBS host/port/password from Broadcast Control Center settings
# Must match the Listener token saved in the browser settings.
PLATFORM_BASE_URL=https://heartlandstormchaser.ike-j-rebout.workers.dev

# OBS WebSocket 5.x defaults (overridden by platform settings when PLATFORM_BASE_URL is set)
OBS_HOST=127.0.0.1
OBS_PORT=4455
OBS_PASSWORD=

# Optional
OBS_RECONNECT_MS=3000
LOG_LEVEL=info

{
  "name": "heartland-storm-chaser",
  "version": "0.1.0",
  "private": true,
  "description": "HeartlandStormChaser — Cloudflare Workers + D1 foundation",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "check": "wrangler check",
    "obs-listener": "npm --prefix services/obs-listener start",
    "obs-listener:install": "npm --prefix services/obs-listener install",
    "test:obs-listener": "npm --prefix services/obs-listener test",
    "home-gps-bridge": "npm --prefix tools/home-gps-bridge start",
    "test:home-gps-bridge": "npm --prefix tools/home-gps-bridge test",
    "weatherfront-obs": "npm --prefix tools/weatherfront-obs-controller start",
    "test:weatherfront-obs": "npm --prefix tools/weatherfront-obs-controller test"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250705.0",
    "typescript": "^5.8.3",
    "wrangler": "^4.24.4"
  }
}
